{
  "name": "pb-headless",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "prettier": "@ibexa/eslint-config/prettier",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prettier:check": "prettier \"./lib/**/*.{js,ts,jsx,tsx,css}\" --check",
    "prettier:fix": "npm run prettier:check -- --write",
    "eslint:check": "eslint \"./lib/**/*.{js,ts,jsx,tsx}\"",
    "eslint:fix": "npm run eslint:check -- --fix",
    "ts:check": "tsc --noEmit --project tsconfig.app.json",
    "cs:check": "npm run prettier:check && npm run eslint:check && npm run ts:check",
    "cs:fix": "npm run prettier:fix && npm run eslint:fix && npm run ts:check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ibexa/eslint-config": "git+https://github.com/ibexa/eslint-config-ibexa.git#v2.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
